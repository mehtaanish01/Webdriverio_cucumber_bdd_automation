{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "types": ["node", "@wdio/globals/types", "@wdio/cucumber-framework"]
  },
"include": [
  "features/step_definitions/**/*.ts",
  "wdio.conf.ts"
],
  "exclude": [
    "node_modules"
  ]
}